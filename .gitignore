# OS / editor cruft
.DS_Store
Thumbs.db
*.swp

# local Claude Code settings (per-machine permissions, not shared)
.claude/settings.local.json

# local server / logs
*.log

# transient build/agent scratch dirs (not part of the shipped site)
_src/
_audit/
_gen/

# graphify knowledge graph: commit the queryable graph, report, manifest, and
# semantic cache (lets `--update` reuse extractions instead of re-spending
# tokens). Never deployed — pages.yml stages only the dashboard folders.
# Ignore machine-specific + cheaply-regenerable bits (no inline comments — git
# treats the whole line as the pattern):
# all graphify scratch/intermediate dotfiles (.graphify_python pointer,
# .graphify_labels.json, .graphify_root, .graphify_*.py step scripts, chunk
# fragments, etc.) — regenerated each run, never part of the committed graph
graphify-out/.graphify_*
graphify-out/.needs_update
graphify-out/needs_update
# local token-spend tracker
graphify-out/cost.json
# 1.25 MB viewer, regenerate any time with /graphify
graphify-out/graph.html
# leftover helper scripts, if any
graphify-out/_*.py
